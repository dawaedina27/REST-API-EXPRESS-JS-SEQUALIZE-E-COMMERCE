              ],
              "path": [
                "api",
                "{{apiVersion}}",
                "users"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Protected",
      "item": [
        {
          "name": "Get Orders (Auth Required)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/orders",
              "host": [
                "{{baseUrl}}"
              ],
