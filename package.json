{
  "name": "express-assignment",
  "version": "1.0.0",
  "description": "E-commerce REST API using Express.js + Sequelize",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "node test/app.test.js",
    "test:unit": "node test/unit/run-unit-tests.js",
    "test:tdd": "nodemon --watch middleware --watch test/unit --ext js --exec \"node test/unit/run-unit-tests.js\"",
    "test:bdd": "cucumber-js --require features/step_definitions/**/*.js",
    "coverage": "c8 --reporter=text --reporter=lcov npm run test",
    "swagger:validate": "node -e \"require('@apidevtools/swagger-parser').validate('docs/swagger.json').then(() => console.log('Swagger spec is valid')).catch((error) => { console.error(error.message); process.exit(1); })\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.15.2",
    "sequelize": "^6.37.7",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@cucumber/cucumber": "^12.8.1",
    "@eslint/js": "^10.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2"
  }
}
